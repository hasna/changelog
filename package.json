{
  "name": "@hasna/changelog",
  "version": "0.2.0",
  "description": "Reusable changelog collection, generation, publishing, CLI, API, SDK, and MCP server for Hasna-coded apps",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "changelog": "dist/cli/index.js",
    "changelog-mcp": "dist/mcp/index.js",
    "changelog-serve": "dist/server/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./markdown": {
      "types": "./dist/markdown.d.ts",
      "import": "./dist/markdown.js"
    },
    "./publisher": {
      "types": "./dist/publisher.d.ts",
      "import": "./dist/publisher.js"
    },
    "./release": {
      "types": "./dist/release.d.ts",
      "import": "./dist/release.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.js"
    },
    "./project": {
      "types": "./dist/project.d.ts",
      "import": "./dist/project.js"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "import": "./dist/storage.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && bun build src/index.ts src/api.ts src/client.ts src/markdown.ts src/publisher.ts src/release.ts src/web.ts src/project.ts src/storage.ts src/validation.ts --outdir dist --root src --target bun && bun build src/cli/index.ts --outdir dist/cli --target bun --external @modelcontextprotocol/sdk && bun build src/mcp/index.ts --outdir dist/mcp --target bun --external @modelcontextprotocol/sdk && bun build src/server/index.ts --outdir dist/server --target bun && tsc -p tsconfig.build.json --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "dev:cli": "bun run src/cli/index.ts",
    "dev:mcp": "bun run src/mcp/index.ts",
    "dev:serve": "bun run src/server/index.ts",
    "prepack": "bun run build",
    "prepublishOnly": "bun run typecheck && bun test",
    "postinstall": "mkdir -p $HOME/.hasna/changelog 2>/dev/null || true"
  },
  "keywords": [
    "changelog",
    "keep-a-changelog",
    "mcp",
    "sdk",
    "cli",
    "api",
    "hasna"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hasna/changelog.git"
  },
  "homepage": "https://github.com/hasna/changelog",
  "bugs": {
    "url": "https://github.com/hasna/changelog/issues"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "author": "Hasna",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "commander": "^13.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.2.4",
    "typescript": "^5.7.3"
  }
}
